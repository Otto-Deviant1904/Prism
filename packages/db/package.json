{
  "name": "@vogue/db",
  "version": "0.1.0",
  "description": "Prisma schema and client",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@vogue/shared": "workspace:*"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.13.0",
    "tsx": "^4.19.4",
    "typescript": "^5.4.5"
  }
}
