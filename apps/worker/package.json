{
  "name": "@vogue/worker",
  "version": "0.1.0",
  "description": "BullMQ worker",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "retry:failed": "tsx scripts/retry-failed.ts",
    "review:rejected": "tsx scripts/review-rejected.ts",
    "test:scrapers": "tsx scripts/test-scrapers.ts",
    "debug:search": "tsx scripts/debug-search.ts",
    "test:queue": "tsx scripts/test-queue.ts",
    "test:golden": "tsx scripts/run-golden.ts",
    "test:normalization": "tsx scripts/test-normalization.ts"
  },
  "dependencies": {
    "@vogue/db": "workspace:*",
    "@vogue/scrapers": "workspace:*",
    "@vogue/shared": "workspace:*",
    "bullmq": "^5.56.0",
    "dotenv": "^16.5.0",
    "ioredis": "^5.4.2",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.4.5"
  }
}
